---
// Shamelessly stolen from https://docs.astro.build/en/guides/content-collections/#using-content-in-astro-templates
import Layout from '@layouts/HTMLLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('writings')).sort(
  (a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Miscelaneous yaps" description="the place where i yap">
<h1>Miscelaneous yaps</h1>
<p>The place where I decide to talk for more than 2 lines!</p>
<p>there's an rss <a href="/blog/feed.xml">here :3</a></p>
{posts.map(post => (
    <div class="post">
        <a href={`/blog/${post.id}`}>{post.data.title}</a> ({post.data.pubDate.toDateString()})<br/>
        {post.data.tags.map(tag => (
        <span class="tag">{tag}</span>
        ))}
    </div>
))}
<style is:global>
  .post {
    background-color: var(--crust);
    border: 2px solid var(--blue);
    padding: 1em;
		margin-bottom: 1em;
    line-height: 2em;
  }

  .tag {
    background-color: var(--text);
    color: var(--base);
    margin-right: 0.5em;
    padding: 1px 6px;
    font-family: "Atkinson Hyperlegible Mono", monospace;
  }
</style>
</Layout>
